{
    "name": "ethelserth/biblionet-php",
    "description": "A PHP client for the Biblionet Greek books API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ethelserth\\Biblionet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ethelserth\\Biblionet\\Tests\\": "tests/"
        }
    }
}